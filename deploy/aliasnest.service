[Unit]
Description=AliasNest FastAPI + SMTP listener
After=network.target

[Service]
Type=simple
User=vagarwal
WorkingDirectory=/home/vagarwal/aliasnest
EnvironmentFile=/home/vagarwal/aliasnest/.env
ExecStart=/home/vagarwal/aliasnest/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
